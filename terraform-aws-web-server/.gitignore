# Terraform state — never commit, contains sensitive resource IDs and secrets
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variable files — may contain AWS credentials or IPs
*.tfvars
!terraform.tfvars.example

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# macOS
.DS_Store
